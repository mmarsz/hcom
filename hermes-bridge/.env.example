# ---- hermes-agent (gateway) ----
# Bot token do @BotFather. NUNCA commitar o real.
TELEGRAM_BOT_TOKEN=
# Allowlist multiuser: user IDs do Telegram separados por vírgula (admin tier à parte).
TELEGRAM_ALLOWED_USERS=
# Habilita a API OpenAI-compat do hermes (http://127.0.0.1:8642/v1/...).
API_SERVER_ENABLED=true
# Chave de auth da API (>= 8 chars). NUNCA commitar o real.
API_SERVER_KEY=

# ---- ponte (forwarder/kanban) ----
# Chat ID do Telegram admin p/ onde o forwarder envia proativas (ex: -1001234567890).
HERMES_FORWARD_TELEGRAM_CHAT_ID=
# Plataforma/destino no formato `hermes send --to` (default: telegram:<chat_id>).
HERMES_FORWARD_TO=
# Intervalo de polling do hcom events (segundos).
HERMES_FORWARD_POLL_INTERVAL=2
# Binário hcom (default: hcom do PATH).
HCOM_PATH=hcom
# Binário hermes (default: hermes do PATH).
HERMES_PATH=hermes
# Porta do kanban FastAPI.
KANBAN_PORT=8643
# Host do kanban (default 127.0.0.1 — POST /spawn e /kill não têm auth; só
# exponha na LAN via reverse proxy com auth). Use 0.0.0.0 só atrás de proxy.
KANBAN_HOST=127.0.0.1
# Allowlist de Telegram user IDs admin (podem spawn/kill). Separados por vírgula.
HERMES_ADMIN_USERS=
